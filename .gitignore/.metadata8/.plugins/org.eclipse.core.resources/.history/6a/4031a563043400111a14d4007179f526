package com.interFaceJDKone.seven.learn;

/*
 * A sealed interface in Java is used to restrict which classes can implement it.
 *  Only the classes explicitly mentioned using 
 *  the permits keyword are allowed to implement 
 *  that interface.

For example, in a banking system, if we define a sealed interface for ATM 
operations, only authorized bank classes
 (approved by an authority like RBI) 
 can implement it. This helps in maintaining control, 
 security, and a well-defined class hierarchy.
 * 
 * */


sealed public interface BankDemo5 implements SBIATMDemo5 , {

	void deposit(double amount);
	void withdraw(double amount);
	double getBalance();
}
