final public class SBIATMDemo5 implements BankDemo5 
{		
	double amount;
					
	
	
	public void deposit(double amount) 
	{
		
		this.amount += amount;
	}
	
	public void withdraw(double amount) {
		if(this.amount > getBalance())
		this.amount -= amount;
	}
	
	
	public double getBalance() 
	{
		return amount;
	}
	
}


