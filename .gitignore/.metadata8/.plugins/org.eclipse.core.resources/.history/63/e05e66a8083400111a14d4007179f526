			}
			case 3->
			{		
				System.out.println("Current Balance is :"+ sbiAtm.getBalance());
				
			}
			default ->
			{
				System.out.println("InvalidChoice Entred");
			}
			}
			System.out.println("Select 1.Withdraw \n 2.Deposit \n 3.Get Balance  \n4.EXIT");
			choice = sc.nextInt();
		}
			
		
	}
	
