	private HowObjectTravelsInNetworkStudentClassCalculateGrade(){
		
	}
	
	public static HowObjectTravelsInNetworkStudentClassStudentGrade  calculateGrade(HowObjectTravelsInNetworkStudentClass student){   
		 
		char studentGrade =' ';
