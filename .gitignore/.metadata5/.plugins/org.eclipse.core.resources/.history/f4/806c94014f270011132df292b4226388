package com.inheritance.learn;

public class MultilevelInheritanceGrandFatherDemo9 {
						
	protected double money= 10000;       //This filed can be accessed inside the same package and in the itss subclasses. 
	protected float land = 10; 
	
	
	protected float totalLand = land; 
	protected double totalMoney = money; 
	
	protected String messageFromYoungGen;
	
	public MultilevelInheritanceGrandFatherDemo9(String message) 
	{   
		super(); 
		messageFromYoungGen = message;
	    
	}
	
	protected void memory()
	{
		
	}
	
	
	
	protected void Land() 
	{
		System.out.println("Grand Father had"+land+"Acres OF land near a river. ");
	}
	
	protected void Money(){   //This method is only accessible in the same package and to its subclasses. 
		System.out.println("Grnadfather Earned Money: "+ money);
	}

	@Override
	public String toString() {
		return "MultilevelInheritanceGrandFatherDemo9 [money=" + money + ", land=" + land + "]";
	}
	
	

}
