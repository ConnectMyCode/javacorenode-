package com.inheritance.learn;

public class MultilevelInheritanceGrandFatherDemo9 {
						
	protected final double money; 
	
	public MultilevelInheritanceGrandFatherDemo9(double money) 
	{
		super(); 
		this.money = money;
	}
	
	protected void Land() 
	{
		System.out.println("10Acres OF land near a river. ");
	}
	
	protected double getMoney(){   //This method is only accessible in the same package and to its subclasses. 
		
		return money;
	}

}
