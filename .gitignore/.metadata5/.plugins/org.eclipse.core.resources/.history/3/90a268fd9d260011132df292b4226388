package com.inheritance.learn;

public class SingleLeevelnheritanceTempEmpDemo2 {
		
	private String tempEmp;
	private double salary; 
	
	
	public SingleLeevelnheritanceTempEmpDemo2(String tempEmp , double salary)
	{    
		 this.tempEmp = tempEmp; 
		 this.salary = salary;  
	}


	public String getTempEmp() {
		return tempEmp;
	}


	public void setTempEmp(String tempEmp) {
		this.tempEmp = tempEmp;
	}


	public double getSalary() {
		return salary;
	}


	public void setSalary(double salary) {
		this.salary = salary;
	}
	
	
	
	
}
