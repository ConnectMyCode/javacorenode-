package com.object.oriented.programming.oop.blc;

public class InstanceBlockOrNonStaticBlockORInstanceInitializerExample1 {
	
	static final int i =0; 
	
	static{	
		System.out.println(i);
	}
	
	{//Instance Blocks
		System.out.println("Its a Instance Initializer block 0 ");
	}
	
	{
		System.out.println("Its a Instance Initializer block 1");
	}

	{
		System.out.println("Its a Instance Initializer block 2");
	}
	
	{
		System.out.println("Its a Instance Initializer block 3"); 
	}
	
	
}
