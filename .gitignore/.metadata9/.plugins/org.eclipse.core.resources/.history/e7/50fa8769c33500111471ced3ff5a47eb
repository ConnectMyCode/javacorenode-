package com.functional.interfaces.learn;



//Functional interface : Interface having only one Abstract method and n numbers of static OR abstract methods

@FunctionalInterface
public interface FunctionaLInterfaceDemo1 {

	void execute();
	
	
	default void  play() 
	{
		System.out.println("Playing is cool!!");
	}
	
	
	static void ground() 
	{
		System.out.println("Ground is scorching Hot!!");
	}
	
}
