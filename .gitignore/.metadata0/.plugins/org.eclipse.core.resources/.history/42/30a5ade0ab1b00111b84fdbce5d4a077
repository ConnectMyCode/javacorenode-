package com.star.pattern.programm;

public class StarPatternProgrammeDemo2 {
	
	public static void  main(String []args) 
	{
		int n = 5; 
		int x = n; //decrease 
		int y= n; //increase
		for(int i=0; i<5; i++) 
		{
			for(int j=0 ; j<2*n-1 ; j++)     //2*n-1=> 10-1 = 9; 
			{
				if(j>=x && j<=y) 
				{
					System.out.print("*");
				}
				else {
					System.out.print(" ");
				}
				
			}
			System.out.println();
			x--;
			y++; 
		}
		
		
	}
	/*   *
	   *  5*8
	 * * *
   * * * * *
 * * * * * * *
* * * * * * * * *
*/
}
