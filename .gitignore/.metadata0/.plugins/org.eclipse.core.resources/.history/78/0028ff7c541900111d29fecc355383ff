package com.star.pattern.programm;

public class StarPatternProgramme {

	
	
	
		public static void main(String []args) 
		{
			int bit=0;
			for(int i=1; i<=5;i++)
			{			
				for(int j=1;j<=5;j++)
				{	
					if(j%2==0)
					{ 
						System.out.print(bit+" ");
						bit--;
					}
					else 
					{
						System.out.print(bit+" ");
						bit++; 
					}
					
				}
				System.out.println();
				bit=0; 
			}
		}
