package com.arrays.programs;

import java.util.*;


public class ArraysTestingDemos {

	public static void main(String []args)  
	{
		Scanner sc= new Scanner(System.in);
		
	/*Anonymous array*/ 
		int[] z={10,20,90,80,70,60,50,40}; //middle = 3
		System.out.println("Before Reversing"+Arrays.toString(z)); 
		
		
		for(int i = 0; i<z.length/2; i++)  
		{
			for(int j=z.length-1; j>z.length/2 ; j--)
			{
				int temp=z[j];
				z[j] = z[i]; 
				z[i] = temp;
			}
		}
		System.out.println("After Modification:"+Arrays.toString(z));
		
		
		
	}
	
}
