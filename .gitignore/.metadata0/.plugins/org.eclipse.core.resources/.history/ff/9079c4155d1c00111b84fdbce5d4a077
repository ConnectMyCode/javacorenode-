		customer[0] = new Customer(111,"Scott",12000);
		customer[1]= new Customer(222,"Roll",13000);
		customer[2]=new Customer(333,"poll",23300);
		customer[3]= new Customer(444,"Doll",40000);
		int j=0;
		for(Customer object: customer) 
