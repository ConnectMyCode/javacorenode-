	 * 2. Initialization through loop and search based in the id
	 **/ 
	
	
/*	Customer cust1 = new Customer(111 ,"Alen", 9000.0);
	Customer cust2 = new Customer(222 ,"Solly", 8000.0);
	Customer cust3 = new Customer(333 ,"joyboy", 7000.0);
	Customer cust4 = new Customer(444 ,"kolly", 6000.0);
