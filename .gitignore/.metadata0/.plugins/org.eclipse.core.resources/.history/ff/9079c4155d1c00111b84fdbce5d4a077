	public static void main(String []args) 
	{	
		
		/* 1. Manual Insertion */ 
		Customer customer[] = new Customer[4];   /*double[] arr =new double[4] ,  int[] arr =new int[9] ,  long[] arr = new long[88] :  similarly Customer customer[] */
		
	    /*arr[0] =1
		 *arr[1]=2
