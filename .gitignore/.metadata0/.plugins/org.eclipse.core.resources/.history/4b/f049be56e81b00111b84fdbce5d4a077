package com.arrays.programs;

public class ArraysDupicateElementsInFindAndPrint {
	
	
	public static void main(String []args) 
	{
		// int array3[] = {90,80,70,60,50,40}; 
		/*Finding duplicate element in array :-> */
		
		int[] array = new int[]{10,20,30,40,50,60,70,70,70,60,20,20}; // 60 70 20 inline initialization 
		
	//	int []array2 = new int[4];
		
		
		for(int i=0; i<=array.length-1; i++)
		{
			for(int j=i+1; j<=array.length-1;j++)  
			{
				if(array[i]==array[j]){  
				   System.out.print(" "+ array[j]);
				   array[j]= -1; //Removed dupliacte elements; 
				   break;
				}
			}
		}
		
		System.out.println();
		for(int element: array) 
		{
			System.out.print(element);
		}
		
		
		/*Removing duplicate elements*/
		
	}

}
