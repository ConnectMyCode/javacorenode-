package com.jvm.architecture;


class Sample
{
	
	static 
	{
		System.out.println("Static Block");
		x=m1(); //Initialization is possible because of prepare phase its been initialized already to default value 0; 
	}
	
	public static int m1() 
	{
		System.out.println("Static Method");
		return 100; 
	}
	
	static int x; 
}

public class StaticBlockDemo1 {
	public static void main(String []args)
	{
		System.out.println("x from main method"+ Sample.x);
	}

}






