package com.arryas.programmes;

public class ArraysLogicUtils {
	
	
	public static double findMinimum(double[] array1)  
	{
		double min =array1[0] ; 
		for(int i= 0; i<array1.length; i++){ 
			for(int j= i+1; j<array1.length; j++){ 
				if(array1[i] > array1[j])  
				{ 
					min = array1[j]; 
				} 
			
			}
		}
		
		return min;  
	}
	

}

