class Customer
{
	
	private int id; 
	private String name; 
	private double bill; 
	
	public Customer(int id, String name ,double bill) 
	{
		this.id = id; 
		this.name = name; 
		this.bill = bill; 
		
		
	}
	
	
	public String toString() 
	{
		return "Customer [id="+id+", name="+name+", bill="+bill+"]"; 
	} 
	   
}
