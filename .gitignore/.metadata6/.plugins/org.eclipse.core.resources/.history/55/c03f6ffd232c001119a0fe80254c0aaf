package com.polymorphism.learn;

public class DownCastingDemo9 {

	public static void main(String []args) 
	{
		// Animal a1= new Dog();
		DownCastingAnimalDemo9 animal = new DownCastingDogDemo9();  //UPCASTING 
		animal.sleep(); 
		
		//I want to access method that is unique to the Dog ->Bark(); method -> It cannot be accessed ERROR: The method bark() is undefined for the type DownCastingAnimalDemo9 
//		animal.bark();   
		
		//Need to Downcasting To access the specific bark() method 
		//WHAT IS DOWNCASTING: -> assigning sub class object to sub class reference variable  via Super class refernce variable is called downcasting
		
		DownCastingDogDemo9 dog = (DownCastingDogDemo9)animal;   
		
		dog.bark();   //Able to use speciffic method
	
	}
}
