package com.polymorphism.learn;

import java.util.Scanner;

public class LooseCouplingDemo14 {

	
	public static void main(String []args)
	{
		Scanner sc = new Scanner(System.in);
		
		System.out.println("Enter a choice for payment Options:  \n 1.Cash Payment  \n 2.Credit Card \n3.Debit Card \n4.UPI Payment \n5.Exit");
		int choice  = sc.nextInt();  
		
		while(choice !=5) 
		{
			switch(choice) 
			{ 
			case 1->{
				System.out.println("Welcome to CASH payment Gateway.");
				LooseCouplingCashPaymentDemo14 cash = new LooseCouplingCashPaymentDemo14();
				paymentSelected(cash);
			}
			case 2->{
				System.out.println("Welcome to Credit Card payment Gateway.");
				LooseCouplingCreditCardPaymentDemo14 credit = new LooseCouplingCreditCardPaymentDemo14(); 
				paymentSelected(credit);
			}
			case 3->{
				System.out.println("Welcome to Debit Card payment Gateway.");
				LooseCouplingDebitCardPaymentDemo14 debit = new LooseCouplingDebitCardPaymentDemo14();
				paymentSelected(debit);
			}
			case 4->{
				System.out.println("Welcome to UPI payment Gateway.");
				LooseCouplingUpiPaymentDemo14 upi = new LooseCouplingUpiPaymentDemo14();
				paymentSelected(upi);
			}
			default->{
				System.out.println("Incorrect input entered Please , enter a correct choice! ");
			}
			
			}			
		}
		
	}
	
     //LOOSE COUPLING:-> A single Parameter can accept Different Type of values each value belonging to different class->Here PARAMETER(paymentGteway) -->Can ACCEPT-->1.Cash 2.Credit 3.Debit 4.UPI           //Upcasting:->   payment<--cash      payment<--Credit   payment<--Debit     payment<--UPI      
	public static void paymentSelected(LooseCouplingPaymentGatewayDemo14 paymentGateway)      
	{
		System.out.println(paymentGateway.message());
	//instnaceof  is a relational operator which return true of the object is of the type Subclass/SuperClass to return false if it is not of type subclass/SuperCLass
		
		if(paymentGateway instanceof LooseCouplingCashPaymentDemo14) //Old Technique(Object instanceof SuperClass/SubClass)      //instanceof--> Checks  the current Object is  instance of or belongs to a super class(using inheritance) or a sub class . If yes return "TRUE" IF no return "FALSE". 		
		{//SafeCASTING --> Chek first is paymentGateway of type Cash if yes then only downcast it this is safeCasting.  	
		//	1way //((LooseCouplingCashPaymentDemo14) paymentGateway).bonus();    //*DownCasting
		
		//2nd Way // 
			LooseCouplingCashPaymentDemo14 cashpay = (LooseCouplingCashPaymentDemo14)paymentGateway ;  //DownCasting:->    Cash<--(Cash)paymentGateway      
		 System.out.println(cashpay.bonus());     
			//Accessing the special method of only Cash Class
		    
		   
		}
		if(paymentGateway instanceof LooseCouplingCreditCardPaymentDemo14 credit) //New Technique(Object instanceof SuperClass/SubClass Reference Variable)  +++  Downcasting  credit<--(credit)paymnentGateway //AfterJDK 16V    
		{
			credit.discount();   //Can access Reason :->  we are  in above if() condition 2 things happened simultaneously 1.DownCasting 2.Verifying using instanceof operator.
			
		}
		if(paymentGateway instanceof LooseCouplingDebitCardPaymentDemo14 debit) 
		{
					debit.offer();
		}
		if(paymentGateway instanceof LooseCouplingUpiPaymentDemo14 upi) 
		{
			upi.challenge();
		}

		
		
	}
	
}
