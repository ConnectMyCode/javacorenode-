package com.polymorphism.learn;

public class InterviewQuestionVehicleDemo7 {

	public int fuelCapacity() 
	{
		return 300; 
	}
	
	
	public void printFuelCapacity() 
	{
		System.out.println(fuelCapacity());    //Will this point to the current class method (Vehicle)  
		//o\p: 280									  //Point TO the current object  (Car Object)
		
		
		
		
		System.out.println(this.fuelCapacity());
		/*Ans:->this.  Point out Current Object method that is Car Object which is being ceated and not Vehicle object:: 
			Reason: The object of the class "Vehicle has not been created then how will the fuelCpacity() Method of class Vehicle work" 
			The Object  created is of "Car class" so its methods are accessible and because the Car inherits Vehicle class it has inherited  the behaviour/Method of Vehicle class as its own by Car class . Naturally the current class method will be pointed by "this." keyword
		*/
	
	}
	
	
}
