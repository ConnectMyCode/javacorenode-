package com.polymorphism.learn;

public class DowncastingDemo12 {
	
	public static void main(String []args) 
	{
	    //1.  FlyMachine machine - new Rocket(); 
		DowncastingDemoFlyMachine12 machine =new DowncastingRocketDemo10();  
		
		machine.fly();   //I can access the common properties using the this reference variable of type Fly Machine. 
		
	//	If I want to access the specific Behaviour of Rocket class I cannot access it So I need to Downcast it . 
		
		//Downcasting: Completed; 
		 
		DowncastingRocketDemo10 rocket = (DowncastingRocketDemo10)machine; 
		rocket.space();
		
		
		//2. FlyMachine machine =new Jet();
		DowncastingDemoFlyMachine12 machine1 = new DowncastingJetDemo12();     
		machine1.fly();      
	//	machine1.earth(); //Cannot access the specific behaviour of the Jet class. 
		
		//To access  Do Downcasting: 
		DowncastingJetDemo12 jet = (DowncastingJetDemo12)machine1; 
		jet.earth();     
		
		
		
		
		
		
		
	}
	

}
