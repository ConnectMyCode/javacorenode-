package com.abstraction.learn;

abstract public class ClassAbstractShapeDemo1 {


	public abstract void foo1(); //Abstract method
	
	public String fool()  //Instance Method
	{
		return "A Fool is full of shit";
	}
	
	public static void peace() //Static Method
	{
		System.out.println("Shit? or Clean?");
	}
	
	static int i = 100;  //Static Field
	
	int j =100;  //Instance Field
	
	static final int  x = 0;  //Static Final Field
	
	final boolean isjoy = true;  //Instance Final Field
	
	static final double y;   
	static 					//Static Block
	{
		y=9000;
		System.out.println("Static Block inside Abstract Class");
	}
	
	final char ch;
	{					 //Instance Block
		ch= 'Q';
		System.out.println("Instance Block inside Abstract Class");		
	}
	

	
	
	
}
