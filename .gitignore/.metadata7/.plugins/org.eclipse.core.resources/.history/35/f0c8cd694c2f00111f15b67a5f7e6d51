package com.record.keyword.learn;

public class NormalEmployeeClassDemo2 
{
	
	private int id; 
	private String name; 
	
	public NormalEmployeeClassDemo2(int id , String name) 
	{
		this.id = id; 
		this.name = name; 
	}

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}
	@Override
	public void setName(String name) {
		this.name = name;
	}

	@Override
	public String toString() {
		return "NormalEmployeeClassDemo2 [id=" + id + ", name=" + name + "]";
	}
	
	
	
	
}
