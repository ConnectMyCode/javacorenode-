package com.record.keyword.learn;

import java.util.Objects;

public class NormalEmployeeClassDemo2 
{
	
	private int id; 
	private String name; 
	
	public NormalEmployeeClassDemo2(int id , String name) 
	{
		this.id = id; 
		this.name = name; 
	}

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}
	
	public void setName(String name) {
		this.name = name;
	}

	@Override
	public String toString() {
		return "NormalEmployeeClassDemo2 [id=" + id + ", name=" + name + "]";
	}

	
	
	@Override
	public int hashCode() {
		return this.id;
	}

	@Override
	public boolean equals(Object obj) {
		if(obj instanceof NormalEmployeeClassDemo2 emp1)   //possible  create a refference variable so downcasting + instanceof Verification is done in one line 
		{
			if(emp1.id == this.id && this.name.equals(emp1.name))
			{
				return true;
			}  
			else {
				return false;
			}
		}
		else {
			System.err.println("Comparison is not possible");
			return false;
		}
	}
	
	
	
	
}
