package com.objectclass.methods.learn;

import java.util.Scanner;

public class EqualsMethod {
//equals() Non static method of Object Class.
 //Used to compare 2 Objects based on the memory reference OR address because Internally it uses == operator.  
	public static void main(String []args) 
	{
		Scanner sc = new Scanner(System.in);

		System.out.println("Enter id and Name pf customer:");
		int id= sc.nextInt();
		String name = sc.next();
		
		EqualsMethodCustomer C1 = new EqualsMethodCustomer(id , name);
		
		System.out.println("Enter id and Name of customer:");
		int id1= sc.nextInt();
		String name1 = sc.next();
		
		EqualsMethodCustomer C2 = new EqualsMethodCustomer(id1, name1);
		
		System.out.println(C1 == C2);    //Compares the address//memory Location of object 

		System.out.println(C1.equals(C2)); 
		
		
		
	}
	
	
}
