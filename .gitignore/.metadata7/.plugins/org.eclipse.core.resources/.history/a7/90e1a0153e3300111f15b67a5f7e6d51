package com.anonymous.inner.classs.learn;

public class AICAbstractClassDemo2 {

	
	public static void main(String []args)
	{
		
		AICAbstractClassVehicleDemo2 car = new AICAbstractClassVehicleDemo2()    // Anonymous  Inner Class Extends Abstract Class
		{
			public void run()
			{
				System.out.println("Car is Running onthe Anonymous INner Class HIGHWAY");
			}

		};
		
		car.run();
		
		/*
		 * “An anonymous inner class can either extend one class or implement one interface at a time. 
		 * It does not support multiple inheritance because Java itself does not allow multiple class inheritance, 
		 * and anonymous class syntax does not allow multiple interface implementation.”
		 * 
		 * */
		
		
		AICAbstractClassVehicleDemo2 bike = new AICAbstractClassVehicleDemo2() 
		{
			public void run() 
			{
				System.out.println("Bike is Running");
			}
		};
		bike.run();
}
	
}
