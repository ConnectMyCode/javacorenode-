package com.objectclass.methods.learn;

public class EqualsMethodEmployeeDemo2 {
	
	private int id; 
	private String name; 
	
	public EqualsMethodEmployeeDemo2(int id , String name) 
	{
		super(); 
		this.id= id; 
		this.name = name;
	}
	
	
	public int hashcode() 
	{
		return this.id;
	}
	
	//Content Comparison
	
	//We use the Str1.equals(Str2) method to compare 2 Strings if they are same then true is returned of not false --> So how is this possible --> "String Class" has overridden the equals() method In its class similar way as shown below. 
	//-->When we Override   
		
	public boolean equals(Object obj)   //Object<---Emloyee  Upcasting //Here Object class can Accept any type of Object Huge Scope not limited Loose coupling
	{
		
		//First Object content
		int id1 = this.id; 
		String name1= this.name; 
		
		//2nd object content 
		//DownCasting
		EqualsMethodEmployeeDemo2 e2= (EqualsMethodEmployeeDemo2)obj; 
		int id2= e2.id; 
		String name2 = e2.name;
		
		
	if(obj instanceof 	EqualsMethodEmployeeDemo2) 
	{
		if(id1 == id2 & name1.equals(name2)) 
		{
			return true ; 
		}
		else 
		{
			return false;
		}
		
	}
	else {
		System.err.println("Comparison is not possible!!!!!"); 
		return false;     
	}
	
	
	
	
	}



	
	

}
