package com.arryas.programmes;

import java.util.Scanner;

public class ArraysLogicUtils {
	static Scanner sc = new Scanner(System.in);
	
	public static int[] reverseArray(int []array3) 
	{
		
		System.out.println("Reverse an array give elements");
		int k=0; 
		for(int element :array3) 
		{
			element = sc.nextInt();
			array3[k] = element;
			k++;
		}
		//{30, 40, 20 ,10}  --> {10, 20 ,40 ,30} 
		              //i<4
		for(int i=0 ; i<array3.length/2 ;i++)
		{                               //j>=2 
			for(int j =array3.length-1;j>=array3.length/2;j--) 
			{
				int temp = array3[i];
				array3[i] = array3[j]; 
				array3[j] = temp;
			}
		}
		
		for(int element :array3) 
		{
			System.out.print(element);
		}
		
		return array3; 
	}
	
	
	
	
