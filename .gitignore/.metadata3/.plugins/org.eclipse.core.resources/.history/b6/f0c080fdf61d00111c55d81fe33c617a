	 * */
	
	
	
	public static void printReverse() 
	{
		int count =5; 
		int n=5; 
		int y=n; 
		
		for(int i=1;i<=5;i++) 
		{
			count=5; 
			for(int j=1;j<=5;j++)
			{
				if(j<=y) 
				{
					System.out.print(count+ " ");
					count--; 
				}
				else
				{
					break; 
				}
			}
			System.out.println();
			y--; 
		}
	}
	/*
	 5 4 3 2 1 
	 5 4 3 2 
     5 4 3 
     5 4 
     5         
	 * */
	
	
	public static void squarePattern() 
	{
		int count =1; 
		
		for(int i = 1 ; i<=5 ;i++) 
		{
			for(int j=1 ; j<=i ;j++) 
			{
				System.out.print(" "+count*count);  
				count++; 
			}
			System.out.println(); 
			 
		}
	}
	
	
	
	/*
	  1
 	  4 9
      16 25 36
      49 64 81 100
      121 144 169 196 225 
    */
	
	
	
	public static void FibonacciPattern() 
	{
		int n =5 ; 
		int x = 1;
		for(int i=1; i<=5; i++) 
		{
			
			int a = 0;
			int b=1; 
			int c = 0 ; 
			for(int j= 1; j<=5 ; j++) 
			{
				
				if(j<=x) 
				{
					a=b; 
					b=c; 
					c=a+b; 
					System.out.print(c+" ");					
				}
				else{
				//	System.out.print(" "); //Time complexity increases 
					break; //To deccrease the time cmplexity 
					
				}
				
			}
			System.out.println();
			x++;
			
			
		}	
		
	}
	
	
	
	
	
	public static void starPatternQOne()  
	{
		int n=5; 
		int x=1; 
		int count =1;
		for(int i=1; i<=5; i++) {
			for(int j= 1; j<=5;j++) 
			{
				if(j==1 && i==1){
					System.out.print(" "+i);
				}
				else if(j<=i) 
				{
					System.out.print(" "+count);
					count++;
				}
				else 
				{
					System.out.print(" ");
				}
				
			}
			System.out.println();
			x++; 
			}
	}
	
}
