	public static void printHashtagsAndZerosInGaps() 
	{
		int n=5; 
		int y = n;
		
		for(int i=1;i<=5;i++) 
		{
			for(int j=1;j<=5;j++) 
			{
				if(j==5 || i==5 ||j>=5) 
				{
					if(j>y && j<n && i<n-1) 
					{
						System.out.print(" 0");
					}
					else {
						System.out.print(" #");
					}
				}
				else {
					System.out.print("  ");
				}
			}
			System.out.println();
			y--; 
			
		}
		
		
	}
	
	
	public static void printHashtags() 
	{
		int n=5; 
		int x= 1; 
		for(int i=1;i<=5;i++) 
		{
			for(int j=1;j<=5;j++) 
			{
				if(j==x || j==n || i==1) 
				{
					System.out.print("# ");
				}
				else
				{
					 System.out.print("  ");
					 
				}
			}
			System.out.println();
			x++;
		} 	
	}
	/*
	   # # # # # 
  	     #     # 
           #   # 
             # # 
