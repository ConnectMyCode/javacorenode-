package com.employee.management.connect.my.code;

import java.util.Scanner;

public class EmployeManagementUtils 
{
	static Scanner sc= new Scanner(System.in);
	
	private EmployeManagementUtils() 
	{} 
	
	
	
	//Search the Employee Data 
	public static boolean SearchEmployee() 
	{     
		  
		
		System.out.println("Enter the employee id to search");
		int idSearch = sc.nextInt();
		
		//DEEP copy or SHALLOW Copy 
		EmployeeObject[] employeeDatabase = EmployeeDatabase.ToSearchCopyDatabaseReturn();
		
		
		for(EmployeeObject empData : employeeDatabase)  //empData here is storing the reference value of the current object 0->1->2
		{
			if(empData.getId() == idSearch) 
			{
				System.out.println("Employee Data Found: "+ empData);
			}
		}
		
		
		
		
		
		
		return true;
	}
	
	
	//To view the data
	public static EmployeeObject[] ViewData() 
	{		
		//returnin the array just after calling the array; 
		return EmployeeDatabase.viewData();  
	}
	
	
	
	//To create Employee object
	public static EmployeeObject addEmployee() 
	{   //String String    Double   String
		// name, contact , salary , position
		
		System.out.println("Enter  Employee ID: ");
		int id = sc.nextInt(); 
		
		System.out.println("Enter  Employee Name: ");
		String name = sc.nextLine();
		
		System.out.println("Enter  Employee Contact: ");
		String contact = sc.next(); 
		
		System.out.println("Enter  Employee Salary: ");
		double numbers = sc.nextDouble();
		
		System.out.println("Enter  Employee Name: ");
		String position = sc.next(); 
		
		/* Creating Employee Object */
		EmployeeObject employee = EmployeeObject.getEmployeeObject( id ,name, contact , numbers , position);
		
		/* Storing the Employee Object Generated in the database using "StoreEmployee" method*/
		EmployeManagementUtils.StoreEmployee(employee);  
		
		 
		
		return  employee;
	}
	
	
	//To Store the employee Data into Database 
	public static void StoreEmployee(EmployeeObject employee) 
	{
		/*Here actual Employee data is store inside the Databse using the static method --> "addEmployeeData" in EmployeeDatabase Class */
		 EmployeeDatabase.addEmployeeData(employee); 
		  
	}
	
	
	
	

}
