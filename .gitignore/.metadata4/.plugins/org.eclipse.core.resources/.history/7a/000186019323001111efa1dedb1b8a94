package com.employee.management.connect.my.code;

import java.util.Scanner;

public class FrontendEmployeeManagement {
	/*
	 * Here employee object is created/Employee registered by the manager of the company when a new employee joins*/
	
 static	Scanner sc = new Scanner(System.in);
	
	public static void main(String []args) 
	{
		//Creating the user interface for using the features that are: 
		/*
		 * 1.ADD EMPLOYEE (Create Employee Object )
		 * 2.STORE EMPLOYEE (Store Employee Object in Database)
		 * 3.VIEW DATA 
		 * 4.SEARCH EMPLOYEE DATA (Search Employee Database)
		 * 5.UPDATE EMPLOYEE DATABASE 
		 * 		-CHANGE ID
		 * 		-CHANGE NAME
		 * 		-CHANGE SALARY
		 * 		-CHANGE POSITION
		 * 		-CHANGE CONTACT*/
		
		int choice = sc.nextInt();   // Layer-2 Data cannot be accessed by layer-1 Data.  
		
		System.out.println("Enter a choice :  \n 1. Add Employee \n 2.View Employee Data \n 3.Search Employee Data  \n4.Update Employee data  \n5.Exit");
		
		while(choice != 5) 
		{
			switch(choice) 
			{
			case 1->{ 	EmployeManagementUtils.addEmployee();	
			}
			case 2->{ EmployeManagementUtils.ViewData(); }
			
			case 3->{System.out.println("Enter the id to search: ");
			int id = sc.nextInt();
			EmployeManagementUtils.SearchEmployee(id);  
			} 
			case 4->{ EmployeManagementUtils.UpdateData(); }
			default->
			{
				System.out.println("Entered a wrong Choice");}
			}
			choice = sc.nextInt();
			System.out.println("Enter a choice :  \n 1. Add Employee \n 2.View Employee Data \n 3.Search Employee Data  \n4.Update Employee data  \n5.Exit");
			
		}
			
		}
	
	
}
