	public static void UpdateData(EmployeeObject employeeObject)   //"employeeObject" -> object from the array as there are 3 present  so passing the object inside the method to make updates to the object properties. 
	{
		/*
		 * 1. Change id 
		 * 2. change name 
		 * 2. change contact 
		 * 2. change salary 
		 * 2. change position 
		 *  */ 
		System.out.println("------------Update Employee Database--------------");     
		System.out.print("Enter 1.Change Id \n 2.Change Name \n3.Change Contact \n4.Change Salary \n5.Change Position \n");   
		int choice = sc.nextInt();
		
		switch (choice) {
		case 1-> {
			

			System.out.println("Enter the new Id to update");
			int id = sc.nextInt();      
			//--------//Data Validation----------------- ? Am i using these words correctly here . What is difference betwenn Data validation and Verification
			if(id<=0){    
				
				System.err.println("ID value cannot be below 0 reneter a proper id ");
				System.exit(0);  
			}
			else 
			{
				/*change id*/		
				System.out.println("Previous Id : "+employeeObject);
								
				employeeObject.setId(id);			//Used to update the ID inside the object; 
				System.out.println("Updated Id : "+employeeObject);
			}		
		}
		case 2-> {
			
			
			System.out.println("Enter new Name to update: ");
			String newName = sc.next(); 
			
			System.out.println("Previous Name:"+employeeObject);
			employeeObject.setName(newName);  //Name has been updated
			System.out.println("Updated Name:"+employeeObject);
			/*However, an object's property in Java is a variable that holds a reference to a string object. A setter method changes that 
			 * reference to point to a different, newly created string object, effectively "updating" the property's value from the perspective 
			 * of the object's user. 
			 * */
					
		}
		case 3->{
			System.out.println("Enter New Contact to update: ");
			String contact = sc.next(); 
			
			if(contact.length()>10) 
			{
				System.out.println("Invalid Conntact please check number");
				System.exit(0);
			}
			else 
			{
				System.out.println("Previous contact is"+employeeObject);
				
				employeeObject.setContact(contact);  //Updated the contact number
				System.out.println("Previous contact is"+employeeObject);
				
				
			}
			
			
			
		}
		case 4->{}
		case 5->{}  
		default->{}
		}
		
		
		
	}
	
	
	
