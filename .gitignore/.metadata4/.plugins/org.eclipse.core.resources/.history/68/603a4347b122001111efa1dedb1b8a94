class Alpha 
{
	protected int x= 100; 
	
	public Alpha() 
	{
		super(); 
		//x=100; 
		
		print();
	}

	public void print() 
	{
		System.out.println("Alpha CLass x is : "+ x);
	}
}



class Beta extends Alpha
{
	protected int x = 200;
	
	
	public Beta() 
	{
		super(); //BETA --> Alpha  
		//2nd Line  x=200; 
	}
	
	public void Print()
	{
		System.out.println("Beta Class x is:" +x);
	}
	
	}

