package com.jvm.architecture;

import java.lang.Class;
import java.lang.reflect.Field; 

class Sample
{
	static
	{
		System.out.println("I am in Method Area!");
	}
	
}

class Joyfull
{
	static int variablePrimitiveOne = 10; 
	static int variablePrimitiveTwo = 20; 
	static int variablePrimitiveThree = 30;
	
	int variableInstance1 = 10;
	int variableInstance2 = 20;
	int variableInstance3 = 30;
	
	public Joyfull() 
	{
		System.out.println("Inside Constructor Body");
	}
	
	public static void print() 
	{
		System.out.println("Inside Static Block"); 
	} 
	
	public void printText() 
	{
		System.out.println("Inside Instance Block");
	}
}


public class ReflectionApiJavaLangClassDemo1Main {

	public static void main(String[] args)throws Exception 
	{
	
		//System.out.println(Class.forName("Sample"));	//It will give classNotFoundException :-> it requires a fully qualified class name that is 
	
		/*Name of the class*/ 
	System.out.println(Class.forName("com.jvm.architecture.Sample")); //Fully qualified name (package Name + Class Name) 
	
	
	/*Here className.method Name is used to call the forName() so it is a Static Method ; 
	 * So no need to create a object to access this method 
	 * Here a Object is created of "Class" type and is saved inside the type "Class" ->" cls " refernce variable 
	 * Now the Obj1 -> has the information about the .Class file like 
	 * 1. Package Name
	 *2. Class Name 
	 *3. Field Declared 
	 *
	 * */
	
	Class cls =  Class.forName("com.jvm.architecture.Joyfull");
	
	System.out.println("Class Name: "+cls.getName()); 
	
	System.out.println("Hash Code: "+cls.hashCode()); 

	System.out.println("Canonical Name:"+cls.getCanonicalName()); 
	System.out.println("Simple Name: "+cls.getSimpleName()); 
	System.out.println("Type Name: "+cls.getTypeName());
	System.out.println("Generic String: "+cls.toGenericString()); 
	
	System.out.println("Class Loader: "+cls.getClassLoader()); 
	
	System.out.println("Method Name: "+cls.getMethods());
	
	System.out.println("Package Name: "+cls.hashCode()); 

	
	/*There are multiple methods and fields inside the class using array to get the Fields and Methods*/
	
	Field[] fields = cls.getDeclaredFields(); 	
	System.out.println("Declared Fields: "+cls.getDeclaredFields()); 
	System.out.println("Declared Methods: "+cls.getDeclaredMethods()); 
	
	System.out.print("Declared Fileds: ");
	for(Field var: fields) 
	{
		System.out.print(var+" ");
	}
	System.out.println(); 
	
	}

}



